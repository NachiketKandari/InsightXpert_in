# Copy to `.env.local` and fill in.

APP_ENV=local
PORT=8080
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# --- auth ---
# SESSION_SECRET must be >=32 chars. Rotate and all cookies invalidate.
SESSION_SECRET=change-me-to-a-long-random-string-please

# WARNING: testing-only bootstrap defaults — change before any non-local deployment.
# These creds seed admin + user accounts on first boot if no users exist.
BOOTSTRAP_ADMIN_EMAIL=admin@insightxpert.ai
BOOTSTRAP_ADMIN_PASSWORD=admin123

BOOTSTRAP_USER_EMAIL=user@insightxpert.ai
BOOTSTRAP_USER_PASSWORD=user@insightxpert.ai123

# --- database --------------------------------------------------------------
# Use Supabase's TRANSACTION POOLER (port 6543) for the runtime URL — it
# pools warm connections at the edge and avoids per-connection TLS
# handshakes. Note the user is `postgres.<project_ref>`, not just
# `postgres` (this is required by the pooler).
#
# Grab from: Supabase dashboard → Project Settings → Database →
# Connection pooling → "Transaction" mode.
DATABASE_URL=postgresql+psycopg://postgres.<project_ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Direct connection (port 5432) is required for Alembic migrations and
# any ops scripts that need session features. If unset, falls back to
# DATABASE_URL.
DATABASE_DIRECT_URL=postgresql+psycopg://postgres:<password>@db.<project_ref>.supabase.co:5432/postgres?sslmode=require

# Connection pool — only active for non-SQLite backends (SQLAlchemy ignores
# these for SQLite). Tune for your Postgres deployment.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_PRE_PING=true

# LLM_PROVIDER: switch between "gemini" and "deepseek"
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# DeepSeek V4 (OpenAI-compatible API). Set DEEPSEEK_API_KEY + LLM_PROVIDER=deepseek
# to switch. When DeepSeek is the chat provider, embeddings still go to Gemini
# (DeepSeek has no embedding API). GEMINI_API_KEY must still be set.
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash

# Storage (empty GCS_BUCKET → local-fs fallback)
GCS_BUCKET=
LOCAL_STORAGE_DIR=./tmp/storage

# Pipeline
MAX_UPLOAD_MB=50
SQL_ROW_LIMIT=1000
SQL_TIMEOUT_SECONDS=30
MAX_REFINEMENT_ITERATIONS=2

# Paths
BUNDLED_DBS_DIR=./Databases

# --- profiling ---
# Columns per LLM call in the batched summary/quirk generators.
# 20 means one prompt handles 20 columns — summary stage costs drop from
# 2×N to ceil(N / PROFILING_BATCH_SIZE) LLM calls.
PROFILING_BATCH_SIZE=20
# Escape hatch — set true to force the vendored per-column path.
PROFILING_BATCH_DISABLED=false
# Hard cap above which every LLM-driven profiling stage auto-disables.
PROFILING_MAX_COLUMNS_FOR_LLM=500

# --- automations (Phase C1) ---
# Master switch. Routes, scheduler, and FE sidebar link all gate on this.
AUTOMATIONS_ENABLED=false
# "embedded" — APScheduler runs inside this process (dev / single-replica).
# "external" — scheduling comes from an external cron posting to
# /api/internal/run-due-automations with an HMAC-signed body.
AUTOMATIONS_SCHEDULER_MODE=embedded
# Required (>=32 bytes, random) when AUTOMATIONS_SCHEDULER_MODE=external.
AUTOMATIONS_SCHEDULER_SECRET=
# Tick interval for the embedded automations scheduler. 30s default;
# do not lower in dev — short ticks against a remote DB amplify load.
AUTOMATIONS_SCHEDULER_TICK_SECONDS=30

# --- observability: Sentry ---
# Leave SENTRY_DSN empty to disable Sentry (no-op). DSN is not secret (also
# used in browser SDKs) so it's safe to commit per-environment values.
SENTRY_DSN=https://2bf6f5307455a0b1a2312e4b5ac6c03a@o4511229689790464.ingest.de.sentry.io/4511264977387600
# Defaults to APP_ENV when blank. Use this to force a different tag, e.g.
# SENTRY_ENVIRONMENT=staging when running a staging build locally.
SENTRY_ENVIRONMENT=
# Git SHA or semantic release string. Lets Sentry group events per release.
SENTRY_RELEASE=
# 0.0 disables performance tracing. Raise in prod if you want transaction
# traces (billable).
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
# Include IP, headers, user email in captured events. OFF by default.
SENTRY_SEND_DEFAULT_PII=false

# --- Connection credential encryption (BYO external DB) ---
# Required when users connect external DBs via /api/v1/connections.
# Generate: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
CREDENTIAL_ENCRYPTION_KEY=
