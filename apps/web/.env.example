# Copy to .env.local and fill as needed.

# Backend origin for direct-to-API SSE streaming (chat + notifications).
# Leave empty to use same-origin via the Next proxy.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Phase C1: Automations feature flag. Gates the routes (/automations,
# /admin/automations), the user-menu link, the admin tab, and the
# notifications SSE hook. Must match backend AUTOMATIONS_ENABLED.
NEXT_PUBLIC_AUTOMATIONS_ENABLED=false

# Optional mock mode for Automations — when true, callers should bypass the
# real API. Currently unused but reserved so the name doesn't get squatted.
NEXT_PUBLIC_AUTOMATIONS_MOCK=false
