{
  "name": "@insightxpert/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types mirroring the backend's Pydantic contracts.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit --target es2022 --module nodenext --moduleResolution nodenext --strict src/index.ts",
    "typecheck": "pnpm run build"
  }
}
