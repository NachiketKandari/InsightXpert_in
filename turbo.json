{
  "$schema": "https://turbo.build/schema.json",
  // DECISION(D-080): npm workspaces (not pnpm) — pnpm symlinks caused Turbopack resolution failures
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": [],
      "dependsOn": ["^build"]
    }
  }
}
